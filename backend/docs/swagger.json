{
    "schemes": [
        "http"
    ],
    "swagger": "2.0",
    "info": {
        "description": "Ini adalah dokumentasi REST API untuk mengelola data mahasiswa dan jurusan.",
        "title": "API Manajemen Mahasiswa",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/api",
    "paths": {
        "/jurusan": {
            "get": {
                "description": "Mengambil seluruh data referensi jurusan untuk dropdown",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Jurusan"
                ],
                "summary": "GetJurusan",
                "responses": {
                    "200": {
                        "description": "Data jurusan berhasil diambil",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/backend-api_internal_models.Jurusan"
                            }
                        }
                    },
                    "500": {
                        "description": "Gagal mengambil data jurusan",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/mahasiswa": {
            "get": {
                "description": "Mengambil semua data mahasiswa beserta detail jurusannya",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "mahasiswa"
                ],
                "summary": "Mengambil Data Mahasiswa",
                "responses": {
                    "200": {
                        "description": "Daftar data mahasiswa",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/backend-api_internal_models.Mahasiswa"
                            }
                        }
                    }
                }
            },
            "post": {
                "description": "Menambahkan data mahasiswa baru ke database",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "mahasiswa"
                ],
                "summary": "Menambahkan Data Mahasiswa",
                "parameters": [
                    {
                        "description": "Data Mahasiswa JSON",
                        "name": "mahasiswa",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/backend-api_internal_models.Mahasiswa"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Data mahasiswa berhasil disimpan",
                        "schema": {
                            "$ref": "#/definitions/backend-api_internal_models.Mahasiswa"
                        }
                    },
                    "400": {
                        "description": "Format data tidak valid",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/mahasiswa/export": {
            "get": {
                "description": "Mengunduh seluruh daftar data mahasiswa ke dalam file Excel (.xlsx) dengan format tanggal bersih (YYYY-MM-DD).",
                "produces": [
                    "application/octet-stream"
                ],
                "tags": [
                    "mahasiswa"
                ],
                "summary": "Export Data Mahasiswa ke Excel",
                "responses": {
                    "200": {
                        "description": "File Laporan_Mahasiswa.xlsx berhasil diunduh",
                        "schema": {
                            "type": "file"
                        }
                    },
                    "500": {
                        "description": "Gagal memproses data atau menulis file Excel",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/mahasiswa/{id}": {
            "put": {
                "description": "Mengupdate data mahasiswa berdasarkan ID",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "mahasiswa"
                ],
                "summary": "Mengupdate Data Mahasiswa",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID Mahasiswa",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Data Mahasiswa JSON",
                        "name": "mahasiswa",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/backend-api_internal_models.Mahasiswa"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Data mahasiswa berhasil diperbarui",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "404": {
                        "description": "Mahasiswa dengan ID tersebut tidak ditemukan",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "delete": {
                "description": "Menghapus data mahasiswa berdasarkan ID",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "mahasiswa"
                ],
                "summary": "Menghapus Data Mahasiswa",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID Mahasiswa",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Data mahasiswa berhasil dihapus",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "404": {
                        "description": "Mahasiswa dengan ID tersebut tidak ditemukan",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "backend-api_internal_models.Jurusan": {
            "type": "object",
            "properties": {
                "fakultas": {
                    "type": "string"
                },
                "id_jurusan": {
                    "type": "integer"
                },
                "jenjang": {
                    "type": "string"
                },
                "nama_jurusan": {
                    "type": "string"
                }
            }
        },
        "backend-api_internal_models.Mahasiswa": {
            "type": "object",
            "properties": {
                "alamat": {
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "id_jurusan": {
                    "type": "integer"
                },
                "jurusan": {
                    "$ref": "#/definitions/backend-api_internal_models.Jurusan"
                },
                "nama": {
                    "type": "string"
                },
                "nim": {
                    "type": "string"
                },
                "tgl_lahir": {
                    "type": "string"
                },
                "umur": {
                    "type": "integer"
                }
            }
        }
    }
}